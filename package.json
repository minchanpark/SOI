{
  "name": "soi-tooling",
  "private": true,
  "description": "Workspace-level scripts for the SOI app and Firebase tooling.",
  "scripts": {
    "api:regen": "bash ./regen_api.sh",
    "api:patch": "bash ./api/patch_generated.sh",
    "functions:lint": "npm --prefix functions run lint",
    "functions:serve": "npm --prefix functions run serve",
    "functions:deploy": "npm --prefix functions run deploy",
    "firebase:emulators": "firebase emulators:start",
    "firebase:hosting:deploy": "firebase deploy --only hosting"
  },
  "engines": {
    "node": ">=22"
  }
}
