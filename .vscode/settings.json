{
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80]
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chatgpt.openOnStartup": false,
  "dart.analysisExcludedFolders": [
    "${workspaceFolder}/.dart_tool",
    "${workspaceFolder}/build",
    "${workspaceFolder}/api/build",
    "${workspaceFolder}/api/generated/.dart_tool",
    "${workspaceFolder}/functions/node_modules",
    "${workspaceFolder}/packages/build",
    "${workspaceFolder}/packages/soi_media_native/.dart_tool",
    "${workspaceFolder}/scripts/profiler/.dart_tool"
  ],
  "eslint.workingDirectories": [
    {
      "directory": "functions",
      "changeProcessCWD": true
    }
  ],
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.dart_tool": true,
    "**/build": true,
    "**/node_modules": true,
    "flutter_*.log": true
  },
  "files.watcherExclude": {
    "**/.dart_tool/**": true,
    "**/build/**": true,
    "**/node_modules/**": true
  },
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": false,
  "search.exclude": {
    "**/.DS_Store": true,
    "**/.dart_tool": true,
    "**/build": true,
    "**/node_modules": true,
    "flutter_*.log": true
  }
}
